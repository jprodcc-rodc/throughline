# Throughline daemon configuration (copy to .env and edit).

# ---------- Paths ----------
# Obsidian vault root (where refined notes are written).
THROUGHLINE_VAULT_ROOT=/path/to/ObsidianVault

# Raw conversation MD root (OpenWebUI exporter target).
THROUGHLINE_RAW_ROOT=/path/to/throughline_runtime/sources/openwebui_raw

# State directory (refine_state.json + cost_stats.json).
THROUGHLINE_STATE_DIR=/path/to/throughline_runtime/state

# Log directory.
THROUGHLINE_LOG_DIR=/path/to/throughline_runtime/logs

# Optional: override packs dir (defaults to repo's packs/).
# THROUGHLINE_PACKS_DIR=/path/to/throughline/packs

# Optional: JSON file with a list of vault path prefixes that must never be
# embedded into the default Qdrant collection. See forbidden_prefixes.example.json.
# THROUGHLINE_FORBIDDEN_PREFIXES_JSON=/path/to/config/forbidden_prefixes.json

# ---------- LLM ----------
OPENROUTER_API_KEY=REPLACE_WITH_YOUR_OPENROUTER_API_KEY
# OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
# THROUGHLINE_LLM_TITLE=throughline-refine-daemon

# Model overrides (each falls back to a sensible default).
# REFINE_SLICE_MODEL=anthropic/claude-sonnet-4.6
# REFINE_SLICE_ONESHOT_MODEL=anthropic/claude-sonnet-4.6
# REFINE_SLICE_OPUS_MODEL=anthropic/claude-opus-4
# REFINE_MODEL=anthropic/claude-sonnet-4.6
# REFINE_ROUTE_MODEL=anthropic/claude-sonnet-4.6
# ECHO_JUDGE_MODEL=anthropic/claude-haiku-4.5
# EPHEMERAL_JUDGE_MODEL=anthropic/claude-haiku-4.5
# EXT_JUDGE_MODEL=google/gemini-3-flash-preview

# ---------- Qdrant ----------
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=knowledge_notes
QDRANT_UPSERT_ENABLED=true
EMBEDDING_URL=http://127.0.0.1:8000/embed

# ---------- Notifications ----------
# SSH target used by daemon/notify.py when running off the notification host.
# Leave empty to silently disable remote notifications.
# THROUGHLINE_NOTIFY_SSH_HOST=user@example.com

# On macOS, desktop notifications default on; disable with:
# MACOS_NOTIFY_ENABLED=false

# ---------- Pipeline tuning ----------
# DEBOUNCE_SECONDS=8
# MAX_RETRY=2
# ECHO_PASS_BELOW=0.60
# ECHO_BLOCK_ABOVE=0.80
# DEDUP_COSINE_THRESHOLD=0.90
# DEDUP_DATE_WINDOW_DAYS=14
# RETENTION_MIN_USER_RATIO=0.18
# RETENTION_MIN_BODY_CHARS=400
# RETENTION_MIN_SECTIONS_COMPLETE=3
